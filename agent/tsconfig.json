{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "outDir": "dist-renderer",
    "rootDir": "src/renderer",
    "declaration": false
  },
  "include": ["src/renderer/**/*.ts", "src/renderer/**/*.tsx"]
}
